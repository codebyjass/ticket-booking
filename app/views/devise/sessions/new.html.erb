<main class="form-signin w-100 m-auto">
  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

    <%= bootstrap_devise_error_messages! %>


    <div class="form-floating">
      <%= f.email_field :email, autofocus: true, autocomplete: 'email', class: 'form-control' %>
      <%= f.label :email, for: 'user_email'%>
    </div>

    <div class="form-floating input-group" data-controller="password">
      <%= f.password_field :password, autocomplete: 'current-password', class: 'form-control password' %>
      <%= f.label :password, for: 'user_password' %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="form-check text-start my-3">
        <%= f.check_box :remember_me, class: 'form-check-input' %>
        <%= f.label :remember_me, class: 'form-check-label' do %>
          <%= resource.class.human_attribute_name('remember_me') %>
        <% end %>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.submit 'Sign In', class: 'btn btn-primary w-100 py-2' %>
    </div>
    <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
      <%= link_to 'Forgot Password', new_password_path(resource_name) %><br />
    <% end -%>
  <% end %>
</main>