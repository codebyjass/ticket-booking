<main class="form-signin w-100 m-auto">
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>

    <%= render partial: 'devise/shared/logo', locals: {title: t('.forgot_your_password')} %>

    <%= bootstrap_devise_error_messages! %>

    <div class="form-floating">
      <%= f.email_field :email, autofocus: true, autocomplete: 'email', class: 'form-control' %>
      <%= f.label :email, for: 'user_email'%>
    </div>

    <div class="mb-2 my-3">
      <%= f.submit 'send me reset password instructions', class: 'btn btn-primary w-100 py-2' %>
    </div>

    <%- if controller_name != 'sessions' %>
      <%= link_to 'Sign In', new_session_path(resource_name) %><br />
      <%= link_to 'Sign Up', new_user_registration_path %><br />
    <% end -%>
  <% end %>
</main>
