<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
  <div class="toast align-items-center hide <%= flash[:alert] ? 'text-danger' : 'text-success' %>" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="d-flex">
      <div class="toast-body">
        <%= notice || flash[:alert] %>
      </div>
      <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
  </div>
</div>
<script>
  <% if notice || flash[:alert] %>
    $('.toast').show().delay(3000).fadeOut(500);
  <% end %>
</script>