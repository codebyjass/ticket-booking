
<%= form_with(model: event) do |f| %>
  <div class="card">
    <div class="card-body">
      <div class="text-danger">
        <ul>
          <% f.object.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
      <div class="d-flex">
        <div class="mb-3 flex-fill">
          <%= f.label :name, { class: "form-label"} %>
          <%= f.text_field :name, { class: "form-control", placeholder: 'Name' } %>
        </div>

        <div class="mb-3 flex-fill">
          <%= f.label :location, { class: "form-label"} %>
          <%= f.text_field :location, { class: "form-control", placeholder: 'Location' } %>
        </div>
      </div>

      <div class="d-flex">
        <div class="mb-3 flex-fill">
          <%= f.label :total_tickets, { class: "form-label"} %>
          <%= f.number_field :total_tickets, { class: "form-control", placeholder: 'Total Tickets' } %>
        </div>

        <div class="mb-3 flex-fill">
          <%= f.label :date, { class: "form-label"} %>
          <%= f.date_field :date, { class: "form-control", placeholder: 'Date/Time' } %>
        </div>
      </div>

      <div class="mb-3"></div>

      <div class="mb-3 flex-fill">
        <%= f.label :description, { class: "form-label"} %>
        <%= f.text_area :description, { class: "form-control", placeholder: 'Description' } %>
      </div>

      <%= f.submit 'Submit', class: "btn btn-primary" %>
    </div>
  </div>
<% end %>